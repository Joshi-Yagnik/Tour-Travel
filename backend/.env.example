# Wanderlust — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ─────────────────────────────────────────────
# Local:  mongodb://localhost:27017/wanderlust
# Atlas:  mongodb+srv://<username>:<password>@cluster.mongodb.net/wanderlust
MONGO_URI=mongodb+srv://joshiyagnik977_db_user:Yagnik123@cluster0.hlt3xfp.mongodb.net/?appName=Cluster0

# ── JWT ─────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=30d

# ── Client URL (CORS) ────────────────────────────────────
CLIENT_URL=http://localhost:5000

# ── Email (Nodemailer) ───────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=joshiyagnik977@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=Wanderlust <joshiyagnik977@gmail.com>
