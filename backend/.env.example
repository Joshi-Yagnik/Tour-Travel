# ── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB Atlas ────────────────────────────────────────────
# Replace with your actual Atlas connection string
MONGO_URI=mongodb+srv://YOUR_DB_USER:YOUR_PASSWORD@cluster0.hlt3xfp.mongodb.net/wanderlust?retryWrites=true&w=majority&appName=Cluster0

# ── JWT Secrets ──────────────────────────────────────────────
# IMPORTANT: Change these to long random strings in production!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_REFRESH_SECRET=your_refresh_token_secret_different_from_jwt_secret
JWT_EXPIRES_IN=7d

# ── Client URL (CORS) ────────────────────────────────────────
CLIENT_URL=http://localhost:5000

# ── Email (Nodemailer/Gmail) ─────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
# Gmail App Password (not your regular password)
# Get it at: Google Account > Security > 2FA > App Passwords
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=Wanderlust <your_email@gmail.com>

# ── Groq AI (Primary) ────────────────────────────────────
# Get FREE key at: https://console.groq.com
# Supports: Llama 3.3 70B, Llama 3.1 8B, Mixtral 8x7B
GROQ_API_KEY=your_groq_api_key_here

# Which provider to use first: groq | gemini
AI_PRIMARY_PROVIDER=groq

# ── Google AI (Gemini) — Fallback ─────────────────────────
# Get free key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── OpenAI (Future) ──────────────────────────────────────
# OPENAI_API_KEY=your_openai_api_key_here

# ── Google OAuth (Optional) ──────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Payment Gateway (Optional) ───────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
